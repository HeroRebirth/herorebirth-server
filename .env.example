#---------------------#
# Hero Rebirth Server #
#---------------------#

# Database (MariaDB / MySQL)
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=herorebirth
DB_CONN_MAX_IDLE=500
DB_CONN_MAX_OPEN=300
DB_CONN_MAX_LIFETIME=50
DB_DEBUG=false
DB_SSL_MODE=

# Game Server
SERVER_IP=127.0.0.1
SERVER_PORT=5310

# Redis (optional — leave REDIS_HOST empty to disable)
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_SCHEME=rediss

# Proxy (Set to 1 if the server is behind HAProxy)
PROXY_ENABLED=0

# Anti-Cheat / Skill Logger (set to false to disable at startup; GM command toggles it at runtime)
SKILL_LOG_ENABLED=true
